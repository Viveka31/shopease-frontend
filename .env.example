# Get this from: dashboard.stripe.com → Developers → API Keys → Publishable key
REACT_APP_STRIPE_PUBLIC_KEY=pk_test_your_publishable_key_here

# Only needed in production (Netlify). Leave blank for local dev (proxy handles it).
# Set to your Render backend URL e.g: https://shopease-api.onrender.com
REACT_APP_API_URL=
